<?php

/**
 * @file
 * FAPI States Ready module.
 */

/**
 * Adds the watcher library as a dependency of Drupal's states library.
 *
 * This module intentionally does not attach its JavaScript globally with
 * hook_page_attachments(). Instead, it alters the core/drupal.states library so
 * that the watcher library is only loaded on pages, forms, or AJAX responses
 * where Drupal's FAPI states system is already being used.
 *
 * This keeps the asset loading strategy narrow:
 * - Pages without #states do not load this module's watcher library.
 * - Pages with #states automatically get the watcher whenever
 *   core/drupal.states is attached.
 * - AJAX responses that attach core/drupal.states also receive the watcher.
 *
 * The watcher JavaScript still performs a lightweight context check before
 * doing any DOM work. That is intentional: Drupal behaviors can be attached
 * repeatedly during AJAX requests, and not every attach context necessarily
 * contains elements with data-drupal-states.
 *
 * Implements hook_library_info_alter().
 */
function fapi_states_ready_library_info_alter(array &$libraries, $extension) {
  if ($extension === 'core' && isset($libraries['drupal.states'])) {
    $libraries['drupal.states']['dependencies'][] = 'fapi_states_ready/watcher';
  }
}
